# =============================================================================
# GradeLoop API Gateway - Environment Variables Template
# Copy this file to .env and configure values
# =============================================================================

# Kong Database Configuration
KONG_DB_PASSWORD=kong_pass_change_me

# JWT Secret Key (for validating tokens - should match IAM service)
JWT_SECRET_KEY=your_super_secret_jwt_key_change_me

# API Gateway Settings
KONG_LOG_LEVEL=info

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000