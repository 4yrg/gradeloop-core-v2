# Keystroke Dynamics Authentication Service — Environment Configuration
# Copy this file to .env and fill in your values.
# All variables without a default are REQUIRED for production.

# ========================================
# PostgreSQL Database
# ========================================
# Connection string for the keystroke service database.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# Docker Compose default:
DATABASE_URL=postgresql://keystroke_user:keystroke_pass@postgres-keystroke:5432/keystroke-db

# ========================================
# Redis Session Storage
# ========================================
# Redis URL for buffering live keystroke events.
# Docker Compose default:
REDIS_URL=redis://redis:6379

# How long to retain a session in Redis before auto-expiry (hours).
# Increase if assignments are long. Default: 2
SESSION_TTL_HOURS=2

# ========================================
# RabbitMQ Event Bus
# ========================================
# Host/port of the RabbitMQ broker for publishing auth events.
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ========================================
# Service
# ========================================
# Port the FastAPI app listens on inside the container.
PORT=8003

# Inference device: cpu or cuda
DEVICE=cpu

# ========================================
# Enrollment & Authentication Thresholds
# ========================================
# Minimum keystroke events required before the ML model can create a template.
MIN_EVENTS_FOR_ENROLLMENT=150

# Minimum events before behavioral analysis runs.
MIN_EVENTS_FOR_ANALYSIS=10

# Similarity threshold for authentication (0–1). Lower = more permissive.
# AUTH_THRESHOLD=0.7

# ========================================
# Anomaly Detection
# ========================================
# Maximum paste operations before flagging as anomaly.
PASTE_THRESHOLD=5

# Typing speed ceiling before "superhuman" flag is raised (chars per minute).
SUPERHUMAN_SPEED_THRESHOLD=400

# Deletion rate below which "no errors" anomaly fires (fraction 0–1).
NO_ERRORS_THRESHOLD=0.01

# ========================================
# Google Gemini AI (Behavioral Analysis)
# ========================================
# Optional. Required only for LLM-powered behavioral analysis reports.
# Get a free key at https://makersuite.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# ========================================
# CORS
# ========================================
# Comma-separated list of allowed origins.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO
ENABLE_DETAILED_LOGGING=false

# ========================================
# Feature Flags
# ========================================
ENABLE_LLM_ANALYSIS=true
ENABLE_RESULT_CACHING=true
