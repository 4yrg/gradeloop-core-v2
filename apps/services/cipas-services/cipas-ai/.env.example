# =============================================================================
# CIPAS AI - 2-Tier Hybrid Code Detection Service
# Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment
# NEVER commit .env file to version control
# =============================================================================

# =============================================================================
# Service Configuration
# =============================================================================
CIPAS_AI_SERVICE_NAME=cipas-ai
CIPAS_AI_SERVICE_VERSION=0.2.0
CIPAS_AI_HOST=0.0.0.0
CIPAS_AI_PORT=8087

# =============================================================================
# Environment Mode
# =============================================================================
# Options: development, staging, production
CIPAS_AI_ENVIRONMENT=development

# =============================================================================
# Model Configuration
# =============================================================================
# Path to Tier 1 CatBoost model (relative to service directory)
CIPAS_AI_TIER1_MODEL_PATH=models/catboost_classifier.cbm

# HuggingFace model name for Tier 2 (ModernBERT-based)
CIPAS_AI_TIER2_MODEL_NAME=project-droid/DroidDetect-Large

# Base ModernBERT encoder
CIPAS_AI_MODERNBERT_BASE_NAME=answerdotai/ModernBERT-large

# =============================================================================
# Quantization Configuration
# =============================================================================
# Enable 4-bit quantization for Tier 2 model (reduces VRAM usage)
# WARNING: Cannot enable both 4-bit and 8-bit simultaneously
CIPAS_AI_ENABLE_4BIT_QUANTIZATION=false

# Enable 8-bit quantization for Tier 2 model (reduces VRAM usage)
CIPAS_AI_ENABLE_8BIT_QUANTIZATION=false

# =============================================================================
# Inference Configuration
# =============================================================================
# Tier 1 confidence thresholds for routing
# If confidence > HIGH_THRESHOLD or < LOW_THRESHOLD, use Tier 1 result
CIPAS_AI_TIER1_HIGH_THRESHOLD=0.92
CIPAS_AI_TIER1_LOW_THRESHOLD=0.08

# Maximum token count for ModernBERT (supports up to 8192)
CIPAS_AI_MAX_TOKENS=8192

# Sliding window configuration for very long inputs
CIPAS_AI_SLIDING_WINDOW_SIZE=4096
CIPAS_AI_SLIDING_WINDOW_OVERLAP=256

# =============================================================================
# Performance Configuration
# =============================================================================
# Number of worker processes (0 = auto-detect CPU cores)
CIPAS_AI_WORKER_COUNT=1

# Enable async inference for Tier 2 (non-blocking)
CIPAS_AI_ENABLE_ASYNC_INFERENCE=true

# Maximum request timeout in seconds
CIPAS_AI_REQUEST_TIMEOUT_SECONDS=60.0

# =============================================================================
# Logging Configuration
# =============================================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
CIPAS_AI_LOG_LEVEL=INFO

# Log format: json or text
CIPAS_AI_LOG_FORMAT=json

# =============================================================================
# Redis Configuration (for async task handling)
# =============================================================================
# Optional: Redis URL for Celery async task handling
# Leave empty to disable async task queue
CIPAS_AI_REDIS_URL=redis://localhost:6379/0
CIPAS_AI_REDIS_MAX_CONNECTIONS=10

# =============================================================================
# Batch Processing Configuration
# =============================================================================
# Maximum number of snippets per batch request
CIPAS_AI_MAX_BATCH_SIZE=100

# Maximum concurrent batch processing
CIPAS_AI_MAX_CONCURRENT_BATCHES=4

# =============================================================================
# Grammar/Parser Configuration
# =============================================================================
# Path to tree-sitter grammar files (relative to service directory)
CIPAS_AI_GRAMMAR_PATH=models

# =============================================================================
# HuggingFace Configuration (Optional)
# =============================================================================
# HuggingFace token for authenticated access (required for some models)
# HUGGING_FACE_TOKEN=your_huggingface_token_here

# =============================================================================
# CUDA Configuration (Optional, for GPU deployments)
# =============================================================================
# Force CUDA device (leave empty for auto-detection)
# CUDA_VISIBLE_DEVICES=0

# =============================================================================
# Production Notes
# =============================================================================
# For production deployments:
# 1. Set CIPAS_AI_ENVIRONMENT=production
# 2. Enable quantization if VRAM is limited (4-bit recommended)
# 3. Configure Redis for async task handling
# 4. Set appropriate worker count based on CPU cores
# 5. Use a reverse proxy (nginx/traefik) in front of the service
# 6. Configure proper CORS origins in main.py
# =============================================================================
