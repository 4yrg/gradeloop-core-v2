# CIPAS AI - Code Detection Service Configuration

# Server settings
HOST=0.0.0.0
PORT=8000

# Model settings
# The model will be downloaded from Hugging Face on first run
# Set this if you want to use a local model path
# MODEL_PATH=/path/to/local/model

# Inference settings
# Threshold for marking code as adversarial (AI-refined)
ADVERSARIAL_THRESHOLD=0.5

# Maximum tokens for optimal model performance
MAX_TOKENS=512

# Logging
LOG_LEVEL=INFO
