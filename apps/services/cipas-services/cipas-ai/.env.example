# =============================================================================
# CIPAS AI - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.
# NEVER commit .env to version control.
# All variables map to config.yaml; env vars take precedence.
# =============================================================================

# =============================================================================
# API Server
# =============================================================================
CIPAS_AI_API_HOST=0.0.0.0
CIPAS_AI_API_PORT=8000

# Options: development, staging, production
CIPAS_AI_ENVIRONMENT=development

# Options: DEBUG, INFO, WARNING, ERROR
CIPAS_AI_LOG_LEVEL=INFO

# =============================================================================
# System / Device
# =============================================================================
# Options: cuda, cpu
CIPAS_AI_SYSTEM_DEVICE=cuda

# =============================================================================
# Model Paths
# =============================================================================
CIPAS_AI_OUTPUT_MODELS_DIR=models
CIPAS_AI_OUTPUT_RESULTS_DIR=results
CIPAS_AI_GRAMMAR_PATH=models

# =============================================================================
# HuggingFace (optional — for authenticated model downloads)
# =============================================================================
# HUGGING_FACE_TOKEN=your_token_here

# =============================================================================
# CUDA (optional)
# =============================================================================
# CUDA_VISIBLE_DEVICES=0
