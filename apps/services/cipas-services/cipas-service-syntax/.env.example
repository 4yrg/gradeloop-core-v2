# Clone Detection Service Configuration

# App metadata
TITLE=Clone Detection Service
DESCRIPTION=API for code clone detection and comparison using Tree-sitter and ML
VERSION=1.0.0

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS settings
ALLOWED_ORIGINS=["*"]
ALLOW_CREDENTIALS=true

# Model settings
MODEL_PATH=data/models/clone_classifier.joblib
DEFAULT_LANGUAGE=java
DEFAULT_THRESHOLD=0.5

# Comparison settings
MAX_CODE_LENGTH=100000
SUPPORTED_LANGUAGES=["python", "java", "c"]
