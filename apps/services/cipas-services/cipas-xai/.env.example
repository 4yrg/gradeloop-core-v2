# Server Configuration
SERVER_PORT=8085
LOG_LEVEL=info

# LLM Configuration
# Provider: openai, anthropic, ollama, etc. (using OpenAI-compatible API)
LLM_PROVIDER=openai

# API Key for the LLM provider
LLM_API_KEY=your-api-key-here

# Base URL for the LLM API
# OpenAI: https://api.openai.com/v1
# Ollama (local): http://localhost:11434/v1
# Other providers: check their OpenAI-compatible endpoint
LLM_BASE_URL=https://api.openai.com/v1

# Model to use
# OpenAI: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
# Ollama: llama2, mistral, etc.
LLM_MODEL=gpt-4o-mini

# Maximum tokens in response
LLM_MAX_TOKENS=2048

# Temperature (0.0 - 2.0): Higher = more creative, Lower = more deterministic
LLM_TEMPERATURE=0.7

# Request timeout in seconds
LLM_TIMEOUT=60
