meta {
  name: Update Avatar
  type: http
  seq: 8
}

patch {
  url: {{AUTH_URL_V1}}/profile/avatar
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{ACCESS_TOKEN}}
}

body:multipart-form {
  avatar: @file(REPLACE_WITH_IMAGE_PATH)
}

docs {
  # Update Avatar
  
  Uploads a new avatar image for the currently authenticated user.
  
  ## Prerequisites
  - Valid access token
  - Image file (JPEG, PNG, GIF, WebP - max 5MB)
}
