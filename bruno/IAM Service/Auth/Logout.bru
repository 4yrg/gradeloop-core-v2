meta {
  name: Logout
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/auth/logout
  body: json
  auth: bearer
}

auth:bearer {
  token: {{jwtToken}}
}

body:json {
  {
    "refresh_token": "{{refreshToken}}"
  }
}
}}"
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("jwtToken", "");
    bru.setEnvVar("refreshToken", "");
  }
}

tests {
  test("Should return 200", function() {
    expect(res.status).to.equal(200);
  });
}