meta {
  name: LTI Launch (Mock)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/lti/launch
  body: form-urlencoded
  auth: none
}

form-urlencoded {
  id_token: eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9..mock-signature
  state: mock-state-001
}

headers {
  X-Tenant-ID: {{tenantId}}
}

tests {
  test("Should redirect or return success in mock mode", function() {
    expect(res.status).to.be.oneOf([200, 302, 303]);
  });
}