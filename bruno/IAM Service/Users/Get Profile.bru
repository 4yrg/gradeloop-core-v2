meta {
  name: Get Profile
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/v1/auth/profile
  auth: bearer
}

auth:bearer {
  token: {{jwtToken}}
}

tests {
  test("Should return 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Should contain user info", function() {
    expect(res.body.email).to.not.be.null;
  });
}