meta {
  name: Get Users By IDs
  type: http
  seq: 8
}

post {
  url: {{USERS_URL_V1}}/bulk
  body: json
  auth: bearer
}

auth:bearer {
  token: {{ACCESS_TOKEN}}
}

body:json {
  {
    "ids": [
      "{{CURRENT_USER_ID}}"
    ]
  }
}

docs {
  # Get Users By IDs
  
  Fetches multiple user profiles in a single request using their IDs.
  
  ## Prerequisites
  - Valid access token
}
