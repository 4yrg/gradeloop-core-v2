meta {
  name: Student Login
  type: http
  seq: 1
}

post {
  url: {{authUrlV1}}/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{student_email}}",
    "password": "{{student_password}}"
  }
}
}}",
  "password": "{{student_password}}"
}

script:post-response {
  if (res.status === 200 && res.body.access_token) {
    bru.setEnvVar("student_token", res.body.access_token);
  }
}