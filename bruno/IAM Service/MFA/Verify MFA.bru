{
  "version": "1",
  "name": "Verify MFA",
  "request": {
    "method": "POST",
    "url": "{{baseUrl}}/api/v1/auth/mfa/verify",
    "body": {
      "mode": "json",
      "json": { "code": "123456" }
    },
    "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] }
  },
  "response": []
}