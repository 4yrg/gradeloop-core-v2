meta {
  name: List Students
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/v1/users/students
  auth: bearer
}

auth:bearer {
  token: {{jwtToken}}
}

tests {
  test("Should return 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Should contain students array", function() {
    expect(res.body.students).to.not.be.null;
  });
}