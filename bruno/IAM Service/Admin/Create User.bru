meta {
  name: Create User
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/users/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{jwtToken}}
}

body:json {
  {
    "email": "newuser@dev.local",
    "password": "password123",
    "fullName": "New User",
    "userType": "student"
  }
}
}

tests {
  test("Should return 201", function() {
    expect(res.status).to.equal(201);
  });
  
  test("Should contain user id", function() {
    expect(res.body.id).to.not.be.null;
  });
}