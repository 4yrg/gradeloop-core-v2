meta {
  name: Preview Import
  type: http
  seq: 2
}

post {
  url: {{USERS_URL_V1}}/import/preview
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{ACCESS_TOKEN}}
}

body:multipart-form {
  file: @file(REPLACE_WITH_CSV_PATH)
}

docs {
  # Preview Import
  
  Uploads a CSV file to preview the users that will be imported.
  
  ## Prerequisites
  - Valid access token
  - Admin privileges
  - CSV file following the template
}
