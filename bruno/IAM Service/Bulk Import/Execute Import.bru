meta {
  name: Execute Import
  type: http
  seq: 3
}

post {
  url: {{usersUrlV1}}/import/execute
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{jwtToken}}
}

body:multipart-form {
  "file": @file(REPLACE_WITH_CSV_PATH)
}

docs {
  # Execute Import
  
  Uploads a CSV file to execute the bulk user import.
  
  ## Prerequisites
  - Valid access token
  - Admin privileges
  - CSV file following the template
}