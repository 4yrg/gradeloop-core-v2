meta {
  name: Health Check
  type: http
  seq: 1
}

get {
  url: {{CIPAS_URL_V1}}/health
  body: none
  auth: none
}

script:post-response {
  if (res.status === 200) {
    console.log("✅ CIPAS service is healthy");
    console.log("Status:", res.body.status);
    console.log("Version:", res.body.version);
  } else {
    console.log("❌ Health check failed");
  }
}

settings {
  encodeUrl: false
  timeout: 5000
}
