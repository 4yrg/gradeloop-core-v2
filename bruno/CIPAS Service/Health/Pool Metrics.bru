meta {
  name: Pool Metrics
  type: http
  seq: 3
}

get {
  url: {{CIPAS_URL_V1}}/metrics/pool
  body: none
  auth: inherit
}

script:post-response {
  if (res.status === 200) {
    console.log("✅ Pool metrics retrieved");
    console.log("Pool size:", res.body.pool_size);
    console.log("Available:", res.body.available);
    console.log("In use:", res.body.in_use);
  } else {
    console.log("❌ Failed to get metrics");
  }
}

settings {
  encodeUrl: false
  timeout: 5000
}
