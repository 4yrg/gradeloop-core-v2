meta {
  name: Service Info
  type: http
  seq: 2
}

get {
  url: {{CIPAS_URL_V1}}/ready
  body: none
  auth: none
}

script:post-response {
  if (res.status === 200) {
    console.log("✅ CIPAS service is ready");
    console.log("Database:", res.body.database);
    console.log("Pipeline:", res.body.pipeline);
  } else {
    console.log("❌ Service not ready");
  }
}

settings {
  encodeUrl: false
  timeout: 5000
}
