meta {
  name: Stream Chat
  type: http
  seq: 4
}

post {
  url: {{CIPAS_XAI_URL_V1}}/chat/stream
  body: json
  auth: inherit
}

body:json {
  {
    "messages": [
      {
        "role": "system",
        "content": "You are a helpful assistant."
      },
      {
        "role": "user",
        "content": "Tell me a short story about a robot learning to paint."
      }
    ],
    "model": "gemini-pro"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
