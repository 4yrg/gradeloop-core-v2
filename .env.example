# =============================================================================
# GradeLoop Core v2 - Global Environment Configuration
# =============================================================================
# This file contains the default environment variables for all microservices.
# Copy this to .env and modify as needed for your environment.

# -----------------------------------------------------------------------------
# Global / Shared Configuration
# -----------------------------------------------------------------------------
APP_ENV=development
JWT_SECRET_KEY=gradeloop_secret_key_change_me
JWT_ACCESS_SECRET=gradeloop_access_secret_change_me
JWT_ALGORITHM=HS256
FRONTEND_URL=http://localhost:3000
ALLOWED_DEV_ORIGINS=http://localhost:3000
API_URL=http://localhost:8000/api/v1
GATEWAY_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
NEXT_PUBLIC_IVAS_API_URL=http://localhost:8000/api/v1/ivas
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# -----------------------------------------------------------------------------
# Shared Infrastructure (PostgreSQL, RabbitMQ, Redis, SeaweedFS/MinIO)
# -----------------------------------------------------------------------------
GRA_DB_USER=postgres
GRA_DB_PASSWORD=postgres
GRA_DB_HOST=localhost
GRA_DB_PORT=5432
GRA_DB_SSLMODE=disable

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=iam_db

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass
REDIS_URL=redis://:redis_pass@localhost:6379

# SeaweedFS (S3-compatible object storage)
SEAWEED_MASTER=localhost:9333
SEAWEED_FILER=localhost:8888
SEAWEED_S3=localhost:8333
MINIO_ROOT_USER=root
MINIO_ROOT_PASSWORD=root
MINIO_ENDPOINT=localhost:8333
MINIO_ACCESS_KEY=root
MINIO_SECRET_KEY=root
MINIO_BUCKET=submissions
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# Service Specific: IAM (Go)
# -----------------------------------------------------------------------------
IAM_SVC_PORT=8081
IAM_SVC_DB_NAME=iam_db
IAM_SVC_ENABLE_PREFORK=false
EMAIL_SERVICE_URL=http://localhost:8082
JWT_ACCESS_TOKEN_EXPIRY=15
JWT_REFRESH_TOKEN_EXPIRY=10080
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax

# IAM Modes (permissive=dev, strict=production)
AUTHZ_MODE=permissive
SSO_MODE=mock
LTI_MODE=mock
ZERO_TRUST_MODE=relaxed
LTI_1_1_ENABLED=true

# -----------------------------------------------------------------------------
# Service Specific: Academic (Go)
# -----------------------------------------------------------------------------
ACADEMIC_SVC_PORT=8083
ACADEMIC_SVC_DB_NAME=academic_db
ACADEMIC_SERVICE_URL=http://localhost:8083
IAM_SERVICE_URL=http://localhost:8081

# -----------------------------------------------------------------------------
# Service Specific: Assessment (Go)
# -----------------------------------------------------------------------------
ASSESSMENT_SVC_PORT=8084
ASSESSMENT_SVC_DB_NAME=assessment_db
ACADEMIC_SERVICE_URL=http://localhost:8083
JUDGE0_URL=http://localhost:2358
JUDGE0_API_KEY=
JUDGE0_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# Service Specific: Email (Go)
# -----------------------------------------------------------------------------
EMAIL_SVC_PORT=8082
EMAIL_SVC_DB_NAME=email_db
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@gradeloop.com

# -----------------------------------------------------------------------------
# Service Specific: IVAS (Python)
# -----------------------------------------------------------------------------
IVAS_SVC_PORT=8101
IVAS_SVC_DB_NAME=ivas_db
IVAS_BASE_URL=http://localhost:8000
IVAS_WS_URL=ws://localhost:8000
IVAS_GEMINI_API_KEY=
IVAS_GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001

# -----------------------------------------------------------------------------
# Service Specific: ACAFS (Python)
# -----------------------------------------------------------------------------
ACAFS_SVC_PORT=8102
ACAFS_SVC_DB_NAME=acafs_db

# -----------------------------------------------------------------------------
# Service Specific: Keystroke (Python)
# -----------------------------------------------------------------------------
KEYSTROKE_SVC_PORT=8103
KEYSTROKE_DATABASE_URL=postgresql://keystroke_user:keystroke_pass@localhost:5433/keystroke-db
KEYSTROKE_DB_PASSWORD=keystroke_pass
KEYSTROKE_REDIS_URL=redis://:redis_pass@localhost:6379
SESSION_TTL_HOURS=2

# -----------------------------------------------------------------------------
# Service Specific: CIPAS Syntactics (Python)
# -----------------------------------------------------------------------------
CIPAS_SYNTACTICS_PORT=8106
CIPAS_SVC_DB_NAME=cipas_db

# -----------------------------------------------------------------------------
# Service Specific: CIPAS Semantics (Python)
# -----------------------------------------------------------------------------
CIPAS_SEM_SVC_PORT=8105
API_PORT=8105

# -----------------------------------------------------------------------------
# Service Specific: CIPAS AI (Python)
# -----------------------------------------------------------------------------
CIPAS_AI_SVC_PORT=8104
CIPAS_AI_SVC_DB_NAME=cipas_ai_db

# -----------------------------------------------------------------------------
# Application Environment (CRITICAL)
# -----------------------------------------------------------------------------
APP_ENV=local  # "local" or "production"

# -----------------------------------------------------------------------------
# Keycloak Identity Provider
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_HOSTNAME_STRICT=false
KEYCLOAK_HTTP_ENABLED=true
KEYCLOAK_REALM=gradeloop-lms

# Keycloak Client IDs (configure in Keycloak admin console)
KEYCLOAK_CLIENT_ID_LMS_WEB=lms-web
KEYCLOAK_CLIENT_ID_LMS_API=lms-api
KEYCLOAK_CLIENT_ID_ADMIN=admin-console
KEYCLOAK_CLIENT_SECRET_LMS_API=your-client-secret-here

# Keycloak IAM Middleware Configuration
# Base URL auto-detected from APP_ENV:
#   local: http://localhost:8080
#   production: https://auth.gradeloop.space
# KEYCLOAK_BASE_URL=http://localhost:8080  # optional override
KEYCLOAK_CLIENT_ID=lms-api
KEYCLOAK_CLIENT_SECRET=your-client-secret-here
KEYCLOAK_JWKS_TTL=24h
KEYCLOAK_DEFAULT_TENANT=dev-university

# Keycloak URLs (auto-constructed from BASE_URL + REALM)
# KEYCLOAK_AUTH_URL=http://localhost:8080
# KEYCLOAK_JWKS_URL=http://localhost:8080/realms/gradeloop-lms/protocol/openid-connect/certs
# KEYCLOAK_TOKEN_URL=http://localhost:8080/realms/gradeloop-lms/protocol/openid-connect/token
# KEYCLOAK_USERINFO_URL=http://localhost:8080/realms/gradeloop-lms/protocol/openid-connect/userinfo
# KEYCLOAK_LOGOUT_URL=http://localhost:8080/realms/gradeloop-lms/protocol/openid-connect/logout
# KEYCLOAK_ADMIN_URL=http://localhost:8080/admin

# -----------------------------------------------------------------------------
# Service Specific: CIPAS XAI (Go)
# -----------------------------------------------------------------------------
CIPAS_XAI_SVC_PORT=8085
LLM_API_KEY=your-openrouter-api-key-here
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=arcee-ai/trinity-large-preview:free
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=60