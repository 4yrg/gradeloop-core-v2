# =============================================================================
# Gradeloop Core v2 - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment
# NEVER commit .env file to version control
# =============================================================================

# =============================================================================
# Service Ports Configuration
# =============================================================================
IAM_SVC_PORT=8081
EMAIL_SVC_PORT=8082

# =============================================================================
# Database Cluster Configuration (Aiven PostgreSQL)
# =============================================================================
GRA_DB_HOST=gradeloop-gradeloop-project-v2.k.aivencloud.com
GRA_DB_USER=avnadmin
GRA_DB_PORT=17317
GRA_DB_PASSWORD=your-database-password
GRA_DB_SSLMODE=require

# Service-specific database names
IAM_SVC_DB_NAME=iam-db
EMAIL_SVC_DB_NAME=email-db

# =============================================================================
# IAM Service Configuration
# =============================================================================
IAM_SVC_ENABLE_PREFORK=true

# =============================================================================
# Frontend Configuration
# =============================================================================
# Update this to your production frontend URL
FRONTEND_URL=http://localhost:3000

# =============================================================================
# SMTP Email Configuration
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_PORT=587

# =============================================================================
# Super Admin Seed Configuration (Initial Setup)
# =============================================================================
# IMPORTANT: Change these credentials in production!
# Password must be strong (min 12 chars, uppercase, lowercase, number, special)
SUPER_ADMIN_USERNAME=superadmin@gradeloop.com
SUPER_ADMIN_PASSWORD=YourSecurePassword123!

# =============================================================================
# JWT Configuration
# =============================================================================
# CRITICAL: Change this to a strong random secret in production (min 32 chars)
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars-change-in-production

# Token expiry in minutes
JWT_ACCESS_TOKEN_EXPIRY=15
JWT_REFRESH_TOKEN_EXPIRY=10080

# =============================================================================
# Assessment Service Configuration
# =============================================================================
ASSESSMENT_SVC_PORT=8084
ASSESSMENT_SVC_ENABLE_PREFORK=true
ASSESSMENT_SVC_DB_NAME=assessment-db
ASSESSMENT_SVC_SUBMISSION_WORKERS=8

# Judge0 Code Execution Service
JUDGE0_URL=http://4.224.42.143:2358
JUDGE0_API_KEY=
JUDGE0_TIMEOUT_SECONDS=30
JUDGE0_MAX_PAYLOAD_SIZE=65536

# =============================================================================
# Academic Service Configuration
# =============================================================================
ACADEMIC_SVC_PORT=8083
ACADEMIC_SVC_ENABLE_PREFORK=true
ACADEMIC_SVC_DB_NAME=academic-db

# =============================================================================
# ACAFS Service Configuration (AST Extraction & Rubric Scoring)
# =============================================================================
ACAFS_SERVICE_NAME=acafs-service
ACAFS_SERVICE_PORT=8086
ACAFS_LOG_LEVEL=INFO
ACAFS_RABBITMQ_EXCHANGE=submissions
ACAFS_RABBITMQ_QUEUE=acafs.evaluation
ACAFS_RABBITMQ_ROUTING_KEY=submission.created
ACAFS_RABBITMQ_CONCURRENCY=4
ACAFS_AST_MAX_LINES=5000
ACAFS_AST_TIMEOUT_SECONDS=2

# LLM Configuration for Semantic Scoring
# Supports OpenAI, OpenRouter, and other OpenAI-compatible APIs
LLM_API_KEY=your-openai-api-key
LLM_MODEL=gpt-4
# LLM_BASE_URL=https://openrouter.ai/api/v1  # Uncomment for OpenRouter

# =============================================================================
# CIPAS Services Configuration (Plagiarism Detection)
# =============================================================================
CIPAS_DB_PASSWORD=cipas_secret
CIPAS_ENV=development
CIPAS_LOG_LEVEL=INFO
CIPAS_PARSER_WORKERS=0
CIPAS_MAX_CONCURRENT_BATCHES=4
CIPAS_SYN_SVC_PORT=8087
CIPAS_SEM_SVC_PORT=8088

# =============================================================================
# MinIO Object Storage Configuration
# =============================================================================
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_BUCKET=submissions
MINIO_PUBLIC_HOST=http://localhost:9000

# =============================================================================
# Kong Gateway Configuration (Optional overrides)
# =============================================================================
# KONG_PROXY_LISTEN=0.0.0.0:8000
# KONG_ADMIN_LISTEN=0.0.0.0:8001
# KONG_LOG_LEVEL=info

# =============================================================================
# Environment Mode
# =============================================================================
# Options: development, staging, production
APP_ENV=development
